<view class="container">
    <view class="header">
        <text class="title">手机号登录</text>
        <text class="subtitle">登录后即可参加活动匹配</text>
    </view>

    <view class="form">
        <!-- 手机号 -->
        <view class="input-group">
            <text class="label">手机号</text>
            <view class="phone-row">
                <text class="country-code">+86</text>
                <input
                    class="input"
                    type="number"
                    maxlength="11"
                    placeholder="请输入手机号"
                    value="{{phone}}"
                    bindinput="onPhoneInput"
                />
            </view>
        </view>

        <!-- 验证码 -->
        <view class="input-group">
            <text class="label">验证码</text>
            <view class="code-row">
                <input
                    class="input code-input"
                    type="number"
                    maxlength="6"
                    placeholder="请输入验证码"
                    value="{{code}}"
                    bindinput="onCodeInput"
                />
                <button
                    class="btn-code {{countdown > 0 || !phoneValid ? 'disabled' : ''}}"
                    disabled="{{countdown > 0 || !phoneValid}}"
                    bindtap="onSendCode"
                >
                    {{countdown > 0 ? countdown + 's' : '获取验证码'}}
                </button>
            </view>
        </view>

        <!-- 邀请码 -->
        <view class="input-group" wx:if="{{!isReturning}}">
            <text class="label">邀请码</text>
            <input
                class="input invite-input"
                maxlength="16"
                placeholder="请输入邀请码"
                value="{{inviteCode}}"
                bindinput="onInviteCodeInput"
            />
        </view>

        <!-- 登录按钮 -->
        <button
            class="btn-login {{!canLogin ? 'disabled' : ''}}"
            disabled="{{!canLogin || loading}}"
            bindtap="onLogin"
        >
            {{loading ? '登录中...' : '登录'}}
        </button>
    </view>

    <view class="footer">
        <text class="footer-text">登录即代表同意</text>
        <text class="footer-link">《用户协议》</text>
        <text class="footer-text">和</text>
        <text class="footer-link">《隐私政策》</text>
    </view>
</view>
