.container {
    min-height: 100vh;
    padding: 0 0 80rpx;
    background: #FFFFFF;
}

/* Hero — 对齐 nira.social 首屏 */
.hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 120rpx 48rpx 40rpx;
}

.hero-brand {
    font-size: 28rpx;
    font-weight: 600;
    color: #999999;
    letter-spacing: 8rpx;
    margin-bottom: 32rpx;
}

.hero-slogan {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.hero-slogan-line {
    font-size: 56rpx;
    font-weight: 800;
    color: #000000;
    letter-spacing: 2rpx;
    line-height: 1.3;
}

.hero-desc {
    font-size: 24rpx;
    color: #999999;
    margin-top: 20rpx;
    letter-spacing: 1rpx;
}

/* Countdown */
.countdown-section {
    text-align: center;
    padding: 48rpx 32rpx;
    margin: 24rpx 32rpx;
    border: 2rpx solid #000000;
}

.countdown-label {
    font-size: 22rpx;
    color: #999999;
    letter-spacing: 4rpx;
    display: block;
    margin-bottom: 32rpx;
}

.countdown-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
}

.countdown-item {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.countdown-num {
    font-size: 64rpx;
    font-weight: 900;
    color: #000000;
    font-variant-numeric: tabular-nums;
    line-height: 1;
}

.countdown-unit {
    font-size: 20rpx;
    color: #999999;
    margin-top: 8rpx;
    letter-spacing: 2rpx;
}

.countdown-sep {
    font-size: 48rpx;
    font-weight: 300;
    color: #CCCCCC;
    margin: 0 4rpx;
    line-height: 64rpx;
}

.countdown-joined {
    display: block;
    font-size: 22rpx;
    color: #000000;
    margin-top: 28rpx;
    letter-spacing: 2rpx;
    font-weight: 600;
}

/* Section heading */
.section-heading {
    font-size: 28rpx;
    font-weight: 800;
    color: #000000;
    letter-spacing: 4rpx;
    display: block;
    margin-bottom: 32rpx;
    padding: 0 8rpx;
}

/* How it works — 4 步流程 */
.how-section {
    padding: 48rpx 32rpx;
    border-top: 2rpx solid #F0F0F0;
}

.step-list {
    display: flex;
    flex-direction: column;
    gap: 32rpx;
}

.step-item {
    display: flex;
    align-items: flex-start;
    gap: 24rpx;
}

.step-num-wrap {
    flex-shrink: 0;
    width: 56rpx;
    height: 56rpx;
    border: 2rpx solid #000000;
    display: flex;
    align-items: center;
    justify-content: center;
}

.step-num {
    font-size: 22rpx;
    font-weight: 800;
    color: #000000;
    letter-spacing: 1rpx;
}

.step-content {
    display: flex;
    flex-direction: column;
    padding-top: 4rpx;
}

.step-title {
    font-size: 28rpx;
    font-weight: 700;
    color: #000000;
    letter-spacing: 1rpx;
}

.step-desc {
    font-size: 24rpx;
    color: #999999;
    margin-top: 6rpx;
    line-height: 1.5;
}

/* AI 特色区域 */
.ai-section {
    padding: 48rpx 0;
    border-top: 2rpx solid #F0F0F0;
}

.ai-card {
    display: flex;
    flex-direction: column;
    gap: 12rpx;
}

.ai-card-title {
    font-size: 28rpx;
    font-weight: 700;
    color: #000000;
    letter-spacing: 1rpx;
}

.ai-card-desc {
    font-size: 24rpx;
    color: #666666;
    line-height: 1.6;
}

/* CTA */
.cta-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 48rpx 32rpx;
    margin-top: 16rpx;
}

.btn-large {
    width: 100%;
    height: 96rpx;
    line-height: 96rpx;
    font-size: 28rpx;
    letter-spacing: 4rpx;
}

.cta-hint {
    font-size: 22rpx;
    color: #999999;
    margin-top: 20rpx;
    letter-spacing: 1rpx;
}

/* Queue Status */
.queue-status-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40rpx 32rpx;
    border: 2rpx solid #000000;
    border-radius: 12rpx;
    width: 100%;
}

.queue-status-icon {
    font-size: 48rpx;
    color: #000000;
    margin-bottom: 16rpx;
}

.queue-status-text {
    font-size: 30rpx;
    font-weight: 700;
    color: #000000;
    letter-spacing: 2rpx;
}

.queue-status-hint {
    font-size: 24rpx;
    color: #999999;
    margin-top: 12rpx;
    letter-spacing: 1rpx;
}
