.container {
    min-height: 100vh;
    background: #FFFFFF;
    padding-bottom: 48rpx;
}

.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 70vh;
}

.loading-text { font-size: 28rpx; color: #999999; letter-spacing: 4rpx; }
.loading-hint { font-size: 22rpx; color: #CCCCCC; margin-top: 20rpx; letter-spacing: 2rpx; }

/* Activity Header */
.activity-header {
    background: #000000;
    color: #FFFFFF;
    padding: 72rpx 48rpx;
}

.activity-type-tag {
    display: inline-block;
    border: 2rpx solid #FFFFFF;
    color: #FFFFFF;
    padding: 6rpx 28rpx;
    font-size: 20rpx;
    letter-spacing: 6rpx;
    text-transform: uppercase;
    margin-bottom: 28rpx;
}

.activity-title {
    display: block;
    font-size: 48rpx;
    font-weight: 900;
    letter-spacing: 4rpx;
    margin-bottom: 20rpx;
}

.activity-desc {
    display: block;
    font-size: 26rpx;
    opacity: 0.6;
    line-height: 1.8;
    letter-spacing: 1rpx;
}

/* Info Card */
.info-card { padding: 40rpx 48rpx; }

.info-row {
    display: flex;
    align-items: center;
    gap: 28rpx;
    padding: 16rpx 0;
}

.info-label { font-size: 22rpx; color: #999999; letter-spacing: 4rpx; width: 80rpx; }
.info-value { font-size: 28rpx; color: #000000; font-weight: 700; letter-spacing: 1rpx; }

/* Section */
.section-title {
    font-size: 22rpx;
    font-weight: 900;
    color: #000000;
    letter-spacing: 6rpx;
    display: block;
    margin-bottom: 24rpx;
    text-transform: uppercase;
}

/* Tips */
.tips-list { display: flex; flex-direction: column; gap: 20rpx; }
.tip-item { display: flex; gap: 20rpx; }
.tip-dot { color: #000000; font-size: 28rpx; line-height: 1.7; font-weight: 900; }
.tip-text { font-size: 28rpx; color: #333333; line-height: 1.7; flex: 1; letter-spacing: 1rpx; }

/* Poster */
.poster-preview {
    border: 2rpx solid #000000;
    padding: 56rpx 48rpx;
    text-align: center;
}

.poster-text {
    font-size: 30rpx;
    font-weight: 700;
    color: #000000;
    line-height: 1.7;
    letter-spacing: 2rpx;
}
.poster-title {
    display: block;
    font-size: 34rpx;
    font-weight: 900;
    color: #000000;
    letter-spacing: 2rpx;
    margin-bottom: 12rpx;
}
.poster-subtitle {
    display: block;
    font-size: 22rpx;
    color: #666666;
    letter-spacing: 2rpx;
    margin-bottom: 20rpx;
}
.poster-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12rpx;
    margin-top: 24rpx;
}
.poster-tag {
    border: 2rpx solid #000000;
    padding: 4rpx 16rpx;
    font-size: 20rpx;
    color: #000000;
    letter-spacing: 2rpx;
}

/* Welcome */
.welcome-text {
    font-size: 28rpx;
    color: #333333;
    line-height: 1.9;
    background: #FAFAFA;
    padding: 32rpx;
    letter-spacing: 1rpx;
}

/* CTA */
.cta-area { padding: 40rpx 32rpx; }
.btn-large { width: 100%; height: 104rpx; line-height: 104rpx; letter-spacing: 6rpx; }
