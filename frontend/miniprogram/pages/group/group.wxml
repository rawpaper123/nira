<view class="container">
    <view class="group-header">
        <text class="group-title">{{groupName || planTitle}}</text>
        <text class="group-subtitle" wx:if="{{planLocation}}">{{planLocation}} · {{planTime}}</text>
    </view>

    <view class="waiting-banner" wx:if="{{noGroup}}">
        <text class="waiting-text">{{welcomeMessage}}</text>
    </view>

    <view class="accepted-banner" wx:if="{{!noGroup}}">
        <text class="accepted-text">{{status || 'group_created'}}</text>
    </view>

    <view class="summary-panel" wx:if="{{activitySummary}}">
        <text class="summary-title">{{activitySummary.title}}</text>
        <text class="summary-line" wx:if="{{activitySummary.suggested_time}}">{{activitySummary.suggested_time}}</text>
        <text class="summary-line" wx:if="{{activitySummary.suggested_location}}">{{activitySummary.suggested_location}}</text>
        <text class="summary-reason" wx:if="{{activitySummary.reason}}">{{activitySummary.reason}}</text>
    </view>

    <view class="icebreaker-panel" wx:if="{{icebreakerQuestions && icebreakerQuestions.length}}">
        <text class="section-title">轻松开场</text>
        <view class="icebreaker-item" wx:for="{{icebreakerQuestions}}" wx:key="index">
            <text>{{item}}</text>
        </view>
    </view>

    <scroll-view class="chat-area" scroll-y scroll-into-view="msg-bottom" scroll-with-animation>
        <view wx:for="{{messages}}" wx:key="id" class="msg-wrapper {{item.isMe ? 'msg-right' : 'msg-left'}}">
            <view wx:if="{{item.isSystem}}" class="msg-system">
                <text class="msg-system-text">{{item.content}}</text>
            </view>
            <view wx:else class="msg-bubble-wrap">
                <view class="msg-sender">
                    <text>{{item.sender}}</text>
                    <text class="msg-time">{{item.time}}</text>
                </view>
                <view class="msg-bubble {{item.isMe ? 'bubble-me' : 'bubble-other'}}">
                    <text>{{item.content}}</text>
                </view>
            </view>
        </view>
        <view id="msg-bottom"></view>
    </scroll-view>

    <view class="input-bar safe-bottom" wx:if="{{!noGroup}}">
        <input
            class="chat-input"
            value="{{inputValue}}"
            placeholder="说点轻松的..."
            confirm-type="send"
            bindinput="onInputChange"
            bindconfirm="onSend"
        />
        <button class="send-btn" catchtap="onSend">发送</button>
    </view>
</view>
