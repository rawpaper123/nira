.container {
    min-height: 100vh;
    background: #FFFFFF;
    display: flex;
    flex-direction: column;
}

.group-header {
    background: #000000;
    padding: 56rpx 48rpx;
    text-align: center;
    color: #FFFFFF;
}

.group-title {
    display: block;
    font-size: 36rpx;
    font-weight: 900;
    letter-spacing: 6rpx;
}

.group-subtitle {
    display: block;
    font-size: 24rpx;
    opacity: 0.5;
    margin-top: 16rpx;
    letter-spacing: 2rpx;
}

/* Waiting Banner — B&W */
.waiting-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16rpx;
    padding: 24rpx 32rpx;
    background: #F5F5F5;
    border-bottom: 2rpx solid #EEEEEE;
}

.waiting-dots {
    display: flex;
    gap: 8rpx;
}

.dot-anim {
    width: 10rpx;
    height: 10rpx;
    background: #000000;
    border-radius: 50%;
    animation: dotPulse 1.4s infinite;
}

.dot-anim:nth-child(2) { animation-delay: 0.2s; }
.dot-anim:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
    0%, 80%, 100% { opacity: 0.15; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1.2); }
}

.waiting-text {
    font-size: 24rpx;
    color: #000000;
    letter-spacing: 2rpx;
    font-weight: 600;
}

/* Accepted Banner — B&W */
.accepted-banner {
    padding: 20rpx 32rpx;
    background: #000000;
    text-align: center;
}

.accepted-text {
    font-size: 24rpx;
    color: #FFFFFF;
    letter-spacing: 4rpx;
    font-weight: 700;
}

.summary-panel,
.icebreaker-panel {
    margin: 28rpx 32rpx 0;
    padding: 28rpx;
    border: 2rpx solid #EEEEEE;
    background: #FFFFFF;
}

.summary-title {
    display: block;
    font-size: 32rpx;
    font-weight: 900;
    color: #000000;
    margin-bottom: 16rpx;
}

.summary-line {
    display: block;
    font-size: 24rpx;
    color: #666666;
    line-height: 1.7;
}

.summary-reason {
    display: block;
    margin-top: 16rpx;
    font-size: 26rpx;
    color: #222222;
    line-height: 1.7;
}

.section-title {
    display: block;
    font-size: 26rpx;
    font-weight: 900;
    color: #000000;
    margin-bottom: 16rpx;
}

.icebreaker-item {
    padding: 18rpx 0;
    border-top: 2rpx solid #F2F2F2;
    font-size: 26rpx;
    color: #222222;
    line-height: 1.7;
}

/* Chat Area */
.chat-area {
    flex: 1;
    padding: 32rpx;
    height: calc(100vh - 360rpx);
}

.msg-wrapper { margin-bottom: 28rpx; }
.msg-right { display: flex; flex-direction: column; align-items: flex-end; }
.msg-left { display: flex; flex-direction: column; align-items: flex-start; }

.msg-system {
    text-align: center;
    padding: 10rpx 28rpx;
    border: 2rpx solid #EEEEEE;
    display: inline-block;
    align-self: center;
    margin: 20rpx 0;
}

.msg-system-text { font-size: 22rpx; color: #999999; letter-spacing: 2rpx; }

.msg-bubble-wrap { max-width: 72%; }

.msg-sender {
    display: flex;
    gap: 12rpx;
    margin-bottom: 6rpx;
    padding: 0 12rpx;
}

.msg-sender text:first-child { font-size: 22rpx; color: #999999; font-weight: 700; letter-spacing: 1rpx; }
.msg-time { font-size: 20rpx; color: #CCCCCC; }

.msg-bubble {
    padding: 20rpx 28rpx;
    font-size: 28rpx;
    line-height: 1.7;
    letter-spacing: 1rpx;
}

.bubble-me {
    background: #000000;
    color: #FFFFFF;
}

.bubble-other {
    background: #F5F5F5;
    color: #000000;
}

/* Input */
.input-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    gap: 16rpx;
    padding: 16rpx 24rpx;
    background: #FFFFFF;
    border-top: 2rpx solid #000000;
}

.chat-input {
    flex: 1;
    height: 76rpx;
    background: #F5F5F5;
    padding: 0 24rpx;
    font-size: 28rpx;
    color: #000000;
    border: none;
}

.send-btn {
    background: #000000;
    color: #FFFFFF;
    height: 76rpx;
    line-height: 76rpx;
    padding: 0 32rpx;
    font-size: 24rpx;
    font-weight: 700;
    letter-spacing: 4rpx;
    border: none;
}

.send-btn::after { border: none; }
