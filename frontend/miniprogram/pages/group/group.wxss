.container {
    min-height: 100vh;
    background: #FFFFFF;
    display: flex;
    flex-direction: column;
}

.group-header {
    background: #000000;
    padding: 48rpx 40rpx;
    text-align: center;
    color: #FFFFFF;
}

.group-title {
    display: block;
    font-size: 36rpx;
    font-weight: 800;
    letter-spacing: 4rpx;
}

.group-subtitle {
    display: block;
    font-size: 24rpx;
    opacity: 0.6;
    margin-top: 12rpx;
}

/* Chat Area */
.chat-area {
    flex: 1;
    padding: 24rpx 24rpx;
}

.msg-wrapper { margin-bottom: 24rpx; }
.msg-right { display: flex; flex-direction: column; align-items: flex-end; }
.msg-left { display: flex; flex-direction: column; align-items: flex-start; }

.msg-system {
    text-align: center;
    padding: 8rpx 24rpx;
    border: 2rpx solid #EEEEEE;
    display: inline-block;
    align-self: center;
    margin: 16rpx 0;
}

.msg-system-text { font-size: 22rpx; color: #999999; letter-spacing: 1rpx; }

.msg-bubble-wrap { max-width: 70%; }

.msg-sender {
    display: flex;
    gap: 12rpx;
    margin-bottom: 4rpx;
    padding: 0 8rpx;
}

.msg-sender text:first-child { font-size: 22rpx; color: #999999; font-weight: 600; }
.msg-time { font-size: 20rpx; color: #CCCCCC; }

.msg-bubble {
    padding: 18rpx 24rpx;
    font-size: 28rpx;
    line-height: 1.6;
}

.bubble-me {
    background: #000000;
    color: #FFFFFF;
}

.bubble-other {
    background: #F5F5F5;
    color: #000000;
}

/* Input */
.input-bar {
    display: flex;
    align-items: center;
    gap: 12rpx;
    padding: 12rpx 24rpx;
    background: #FFFFFF;
    border-top: 2rpx solid #000000;
}

.chat-input {
    flex: 1;
    height: 68rpx;
    background: #F5F5F5;
    padding: 0 20rpx;
    font-size: 28rpx;
    color: #000000;
}

.send-btn {
    background: #000000;
    color: #FFFFFF;
    height: 68rpx;
    line-height: 68rpx;
    padding: 0 28rpx;
    font-size: 24rpx;
    font-weight: 600;
    letter-spacing: 2rpx;
    border: none;
}

.send-btn::after { border: none; }

.send-btn[disabled] {
    background: #E0E0E0;
    color: #FFFFFF;
}

.send-btn-active { background: #000000; }

.home-cta {
    padding: 20rpx 32rpx 32rpx;
    background: #FFFFFF;
}
