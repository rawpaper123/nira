.container {
    min-height: 100vh;
    background: #FFFFFF;
    padding-bottom: 48rpx;
}

/* Loading / Error */
.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 60vh;
}

.loading-text { font-size: 28rpx; color: #999999; letter-spacing: 2rpx; }
.loading-hint { font-size: 22rpx; color: #CCCCCC; margin-top: 16rpx; }

/* Header */
.match-header {
    text-align: center;
    padding: 48rpx 32rpx 16rpx;
}

.week-label {
    font-size: 22rpx;
    color: #000000;
    border: 2rpx solid #000000;
    padding: 4rpx 24rpx;
    letter-spacing: 4rpx;
}

.match-title {
    display: block;
    font-size: 40rpx;
    font-weight: 800;
    color: #000000;
    margin-top: 20rpx;
    letter-spacing: 4rpx;
}

/* Score */
.score-section {
    display: flex;
    justify-content: center;
    padding: 40rpx 0 24rpx;
}

.score-ring {
    width: 200rpx;
    height: 200rpx;
    border: 6rpx solid #000000;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.score-number { font-size: 72rpx; font-weight: 900; color: #000000; line-height: 1; }
.score-unit { font-size: 20rpx; color: #999999; margin-top: 4rpx; letter-spacing: 4rpx; }

/* Match Card */
.match-card { display: flex; align-items: center; }
.match-user { display: flex; align-items: center; gap: 24rpx; }

.match-avatar-fallback {
    width: 88rpx;
    height: 88rpx;
    border: 2rpx solid #000000;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000000;
    font-size: 28rpx;
    font-weight: 800;
}

.match-info { display: flex; flex-direction: column; }
.match-name { font-size: 32rpx; font-weight: 700; color: #000000; letter-spacing: 2rpx; }
.match-score-text { font-size: 24rpx; color: #999999; margin-top: 4rpx; }

/* Sections */
.section-title {
    font-size: 24rpx;
    font-weight: 700;
    color: #000000;
    letter-spacing: 4rpx;
    display: block;
    margin-bottom: 20rpx;
}

.section-header { display: flex; justify-content: space-between; align-items: center; }
.toggle-icon { font-size: 22rpx; color: #999999; }
.reasoning-text { font-size: 26rpx; color: #333333; line-height: 1.8; }

/* Score Bars */
.score-bars { display: flex; flex-direction: column; gap: 24rpx; }
.score-bar-item { display: flex; align-items: center; gap: 16rpx; }
.score-bar-label { font-size: 22rpx; color: #999999; width: 120rpx; flex-shrink: 0; letter-spacing: 1rpx; }

.score-bar {
    flex: 1;
    height: 8rpx;
    background: #F5F5F5;
    overflow: hidden;
}

.score-bar-fill {
    height: 100%;
    background: #000000;
    transition: width 0.6s ease;
}

.score-bar-value { font-size: 24rpx; color: #000000; width: 80rpx; text-align: right; flex-shrink: 0; font-weight: 700; }

/* Simulation */
.sim-hint { font-size: 22rpx; color: #999999; margin-top: 8rpx; display: block; letter-spacing: 1rpx; }

.sim-content {
    margin-top: 24rpx;
    display: flex;
    flex-direction: column;
    gap: 24rpx;
}

.sim-scene {
    border: 2rpx solid #EEEEEE;
    padding: 24rpx;
}

.scene-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12rpx;
}

.scene-badge {
    font-size: 20rpx;
    border: 2rpx solid #000000;
    color: #000000;
    padding: 2rpx 16rpx;
    letter-spacing: 2rpx;
}

.scene-vibe { font-size: 22rpx; color: #999999; }
.scene-scenario { font-size: 24rpx; color: #666666; display: block; margin-bottom: 12rpx; }

.scene-chat {
    background: #F5F5F5;
    padding: 16rpx;
}

.scene-dialog { font-size: 24rpx; color: #333333; line-height: 1.8; white-space: pre-wrap; }

/* CTA */
.cta-area { padding: 32rpx; }
.btn-large { width: 100%; height: 96rpx; line-height: 96rpx; letter-spacing: 4rpx; }

.btn-reject {
    background: transparent;
    color: #999999;
    border: none;
    font-size: 26rpx;
    margin-top: 20rpx;
    text-align: center;
    letter-spacing: 1rpx;
    padding: 20rpx 0;
}

.btn-reject::after { border: none; }
