.container {
    min-height: 100vh;
    background: #FFFFFF;
    padding-bottom: 48rpx;
}

/* Loading / Error */
.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 70vh;
}

.loading-text { font-size: 28rpx; color: #999999; letter-spacing: 4rpx; }
.loading-hint { font-size: 22rpx; color: #CCCCCC; margin-top: 20rpx; letter-spacing: 2rpx; }

/* Header */
.match-header {
    text-align: center;
    padding: 64rpx 32rpx 24rpx;
}

.week-label {
    font-size: 20rpx;
    color: #000000;
    border: 2rpx solid #000000;
    padding: 6rpx 28rpx;
    letter-spacing: 6rpx;
    text-transform: uppercase;
}

.match-title {
    display: block;
    font-size: 48rpx;
    font-weight: 900;
    color: #000000;
    margin-top: 28rpx;
    letter-spacing: 6rpx;
}

/* Score */
.score-section {
    display: flex;
    justify-content: center;
    padding: 56rpx 0 32rpx;
}

.score-ring {
    width: 220rpx;
    height: 220rpx;
    border: 6rpx solid #000000;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.score-number { font-size: 80rpx; font-weight: 900; color: #000000; line-height: 1; }
.score-unit { font-size: 20rpx; color: #999999; margin-top: 8rpx; letter-spacing: 4rpx; text-transform: uppercase; }

/* Match Card */
.match-card { display: flex; align-items: center; }
.match-user { display: flex; align-items: center; gap: 28rpx; }

.match-avatar-fallback {
    width: 96rpx;
    height: 96rpx;
    border: 2rpx solid #000000;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000000;
    font-size: 32rpx;
    font-weight: 900;
}

.match-info { display: flex; flex-direction: column; }
.match-name { font-size: 34rpx; font-weight: 800; color: #000000; letter-spacing: 4rpx; }
.match-score-text { font-size: 24rpx; color: #999999; margin-top: 6rpx; letter-spacing: 2rpx; }

/* Sections */
.section-title {
    font-size: 22rpx;
    font-weight: 900;
    color: #000000;
    letter-spacing: 6rpx;
    display: block;
    margin-bottom: 24rpx;
    text-transform: uppercase;
}

.section-header { display: flex; justify-content: space-between; align-items: center; }
.toggle-icon { font-size: 24rpx; color: #000000; font-weight: 300; }
.reasoning-text { font-size: 28rpx; color: #333333; line-height: 1.9; letter-spacing: 1rpx; }

/* Score Bars */
.score-bars { display: flex; flex-direction: column; gap: 28rpx; }
.score-bar-item { display: flex; align-items: center; gap: 20rpx; }
.score-bar-label { font-size: 22rpx; color: #999999; width: 120rpx; flex-shrink: 0; letter-spacing: 2rpx; }

.score-bar {
    flex: 1;
    height: 4rpx;
    background: #F0F0F0;
    overflow: hidden;
}

.score-bar-fill {
    height: 100%;
    background: #000000;
    transition: width 0.6s ease;
}

.score-bar-value { font-size: 24rpx; color: #000000; width: 80rpx; text-align: right; flex-shrink: 0; font-weight: 800; letter-spacing: 1rpx; }

/* Simulation */
.sim-hint { font-size: 22rpx; color: #999999; margin-top: 12rpx; display: block; letter-spacing: 2rpx; }

.sim-content {
    margin-top: 28rpx;
    display: flex;
    flex-direction: column;
    gap: 24rpx;
}

.sim-scene {
    border: 2rpx solid #EEEEEE;
    padding: 28rpx;
}

.scene-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16rpx;
}

.scene-badge {
    font-size: 18rpx;
    border: 2rpx solid #000000;
    color: #000000;
    padding: 4rpx 20rpx;
    letter-spacing: 4rpx;
    text-transform: uppercase;
}

.scene-vibe { font-size: 22rpx; color: #999999; font-weight: 600; }
.scene-scenario { font-size: 24rpx; color: #666666; display: block; margin-bottom: 16rpx; line-height: 1.6; }

.scene-chat {
    background: #FAFAFA;
    padding: 20rpx;
}

.scene-dialog { font-size: 24rpx; color: #333333; line-height: 1.9; white-space: pre-wrap; letter-spacing: 1rpx; }

/* CTA */
.cta-area { padding: 40rpx 32rpx; }
.btn-large { width: 100%; height: 104rpx; line-height: 104rpx; letter-spacing: 6rpx; }

.btn-reject {
    background: transparent;
    color: #999999;
    border: none;
    font-size: 26rpx;
    margin-top: 24rpx;
    text-align: center;
    letter-spacing: 2rpx;
    padding: 24rpx 0;
}

.btn-reject::after { border: none; }
