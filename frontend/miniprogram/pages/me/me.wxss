.container {
    min-height: 100vh;
    background: #FFFFFF;
    padding-bottom: env(safe-area-inset-bottom);
}

/* ---- Profile Header ---- */
.profile-header {
    display: flex;
    align-items: center;
    padding: 72rpx 48rpx 56rpx;
    background: #000000;
    color: #FFFFFF;
}

.avatar-wrap {
    flex-shrink: 0;
}

.avatar-fallback {
    width: 104rpx;
    height: 104rpx;
    border: 3rpx solid #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
}

.avatar-text {
    font-size: 40rpx;
    font-weight: 900;
    color: #FFFFFF;
    letter-spacing: 2rpx;
}

.profile-info {
    flex: 1;
    margin-left: 32rpx;
    display: flex;
    flex-direction: column;
}

.nickname {
    font-size: 36rpx;
    font-weight: 800;
    letter-spacing: 4rpx;
}

.user-id {
    font-size: 22rpx;
    opacity: 0.4;
    margin-top: 8rpx;
    letter-spacing: 2rpx;
}

.edit-btn {
    flex-shrink: 0;
    border: 2rpx solid #FFFFFF;
    padding: 10rpx 32rpx;
    font-size: 24rpx;
    letter-spacing: 4rpx;
    font-weight: 600;
}

/* ---- Queue Card ---- */
.queue-card {
    margin-top: 32rpx;
}

.queue-status-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.queue-label {
    font-size: 28rpx;
    font-weight: 800;
    color: #000000;
    letter-spacing: 2rpx;
}

.queue-badge {
    font-size: 20rpx;
    padding: 6rpx 24rpx;
    letter-spacing: 4rpx;
    font-weight: 700;
}

.badge-active {
    background: #000000;
    color: #FFFFFF;
}

.badge-inactive {
    border: 2rpx solid #CCCCCC;
    color: #CCCCCC;
}

.queue-hint {
    display: block;
    font-size: 22rpx;
    color: #999999;
    margin-top: 20rpx;
    letter-spacing: 2rpx;
}

/* ---- Profile Card ---- */
.profile-card {
    display: flex;
    flex-direction: column;
}

.section-title {
    font-size: 22rpx;
    font-weight: 900;
    color: #000000;
    letter-spacing: 6rpx;
    display: block;
    margin-bottom: 24rpx;
    text-transform: uppercase;
}

.tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 12rpx;
}

/* ---- Section Block ---- */
.section-block {
    padding: 0 32rpx;
    margin-top: 48rpx;
}

.section-heading {
    font-size: 22rpx;
    font-weight: 900;
    color: #000000;
    letter-spacing: 6rpx;
    display: block;
    margin-bottom: 24rpx;
    padding: 0 8rpx;
    text-transform: uppercase;
}

/* ---- Match History ---- */
.history-card {
    padding: 32rpx 40rpx;
}

.history-card + .history-card {
    margin-top: 16rpx;
}

.history-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.history-left {
    display: flex;
    flex-direction: column;
}

.history-activity {
    font-size: 28rpx;
    font-weight: 700;
    color: #000000;
    letter-spacing: 1rpx;
}

.history-date {
    font-size: 22rpx;
    color: #999999;
    margin-top: 6rpx;
    letter-spacing: 1rpx;
}

.history-right {
    display: flex;
    align-items: center;
    gap: 20rpx;
}

.history-score {
    font-size: 36rpx;
    font-weight: 900;
    color: #000000;
}

.history-status {
    font-size: 20rpx;
    padding: 4rpx 20rpx;
    letter-spacing: 2rpx;
}

.status-accepted {
    background: #000000;
    color: #FFFFFF;
}

.status-rejected {
    border: 2rpx solid #CCCCCC;
    color: #999999;
}

.status-completed {
    background: #F5F5F5;
    color: #000000;
}

.empty-text {
    font-size: 26rpx;
    color: #CCCCCC;
    text-align: center;
    display: block;
    padding: 24rpx 0;
    letter-spacing: 2rpx;
}

/* ---- Settings ---- */
.settings-card {
    padding: 0;
}

.settings-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 36rpx 48rpx;
}

.settings-label {
    font-size: 28rpx;
    color: #000000;
    letter-spacing: 2rpx;
}

.settings-arrow {
    font-size: 36rpx;
    color: #CCCCCC;
    font-weight: 300;
}

.settings-divider {
    height: 2rpx;
    background: #F0F0F0;
    margin: 0 48rpx;
}

/* ---- Logout ---- */
.logout-area {
    padding: 56rpx 32rpx 0;
}

.btn-logout {
    background: #FFFFFF;
    color: #000000;
    border: 2rpx solid #000000;
    border-radius: 0;
    font-size: 28rpx;
    font-weight: 700;
    letter-spacing: 6rpx;
    padding: 28rpx 0;
    text-align: center;
}

.btn-logout::after {
    border: none;
}
