<view class="container">
    <!-- 顶部用户信息区 -->
    <view class="profile-header">
        <view class="avatar-wrap">
            <view class="avatar-fallback">
                <text class="avatar-text">我</text>
            </view>
        </view>
        <view class="profile-info">
            <text class="nickname">{{nickname}}</text>
            <text class="user-id">ID: {{userId}}</text>
        </view>
        <view class="edit-btn" catchtap="onEditProfile">
            <text>编辑</text>
        </view>
    </view>

    <!-- 队列状态卡片 -->
    <view class="card queue-card" wx:if="{{profileComplete}}">
        <view class="queue-status-row">
            <text class="queue-label">匹配队列</text>
            <text class="queue-badge {{joinedQueue ? 'badge-active' : 'badge-inactive'}}">
                {{joinedQueue ? '已加入' : '未加入'}}
            </text>
        </view>
        <text class="queue-hint" wx:if="{{joinedQueue}}">下周三 19:00 揭晓匹配结果</text>
        <text class="queue-hint" wx:if="{{!joinedQueue && profileComplete}}">完成画像后可加入本周匹配</text>
    </view>

    <!-- 画像状态 -->
    <view class="card profile-card" wx:if="{{profileComplete}}">
        <text class="section-title">我的画像</text>
        <view class="tag-list">
            <text class="tag" wx:for="{{profileTags}}" wx:key="index">{{item}}</text>
        </view>
    </view>

    <!-- 匹配历史 -->
    <view class="section-block">
        <text class="section-heading">匹配历史</text>
        <view class="card history-card" wx:if="{{matchHistory.length === 0}}">
            <text class="empty-text">暂无匹配记录</text>
        </view>
        <view class="card history-card" wx:for="{{matchHistory}}" wx:key="id">
            <view class="history-row">
                <view class="history-left">
                    <text class="history-activity">{{item.activity}}</text>
                    <text class="history-date">{{item.date}}</text>
                </view>
                <view class="history-right">
                    <text class="history-score">{{item.score}}%</text>
                    <text class="history-status status-{{item.status}}">{{item.statusText}}</text>
                </view>
            </view>
        </view>
    </view>

    <!-- 设置列表 -->
    <view class="section-block">
        <text class="section-heading">设置</text>
        <view class="card settings-card">
            <view class="settings-item" catchtap="onNotificationTap">
                <text class="settings-label">通知设置</text>
                <text class="settings-arrow">›</text>
            </view>
            <view class="settings-divider"></view>
            <view class="settings-item" catchtap="onPrivacyTap">
                <text class="settings-label">隐私政策</text>
                <text class="settings-arrow">›</text>
            </view>
            <view class="settings-divider"></view>
            <view class="settings-item" catchtap="onAboutTap">
                <text class="settings-label">关于 Nira</text>
                <text class="settings-arrow">›</text>
            </view>
        </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-area">
        <button class="btn-logout" catchtap="onLogout">退出登录</button>
    </view>

    <!-- 底部留白 -->
    <view style="height: 120rpx;"></view>
</view>
