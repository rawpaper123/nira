<view class="chat-container">
    <scroll-view class="chat-list" scroll-y enhanced style="height: calc(100vh - {{chatComplete ? 240 : 140}}rpx)">
        <view wx:for="{{messages}}" wx:key="id" id="msg-{{index}}">
            <chat-bubble message="{{item.text || ''}}" isUser="{{item.isUser}}"></chat-bubble>
        </view>
        <chat-bubble wx:if="{{isAiTyping}}" isTyping="{{true}}"></chat-bubble>
        <view id="scroll-bottom"></view>
    </scroll-view>

    <view class="onboarding-hint" wx:if="{{!fromPush && onboardingHint}}">
        <text>{{onboardingHint}}</text>
    </view>

    <view class="input-bar safe-bottom" wx:if="{{!chatComplete && !fromPush}}">
        <input
            class="chat-input"
            value="{{inputValue}}"
            placeholder="{{inputPlaceholder}}"
            placeholder-class="input-placeholder"
            confirm-type="send"
            bindinput="onInputChange"
            bindconfirm="onSend"
            disabled="{{isAiTyping}}"
        />
        <button
            class="send-btn {{inputValue ? 'send-btn-active' : ''}}"
            catchtap="onSend"
            disabled="{{!inputValue || isAiTyping}}"
        >
            发送
        </button>
    </view>

    <view class="match-cta safe-bottom" wx:if="{{fromPush}}">
        <button class="btn-primary btn-match" catchtap="onViewMatchDetail">View match result</button>
        <button class="btn-secondary" style="margin-top: 12rpx;" bindtap="onGoHome">Back home</button>
    </view>

    <view class="match-cta safe-bottom" wx:if="{{!fromPush && chatComplete && alreadyJoined}}">
        <view class="queue-done-card">
            <text class="queue-done-icon">✓</text>
            <text class="queue-done-text">已加入本周匹配队列</text>
            <text class="queue-done-hint">等待本周匹配结果</text>
        </view>
        <button class="btn-secondary" style="margin-top: 16rpx;" bindtap="onGoHome">返回首页</button>
        <button class="btn-secondary" style="margin-top: 12rpx;" bindtap="onContinueChat">继续修改偏好</button>
    </view>

    <view class="match-cta safe-bottom" wx:if="{{!fromPush && chatComplete && !alreadyJoined}}">
        <button class="btn-primary btn-match" catchtap="onJoinQueue" disabled="{{isJoiningQueue}}">
            {{isJoiningQueue ? '加入中...' : '加入本周匹配队列'}}
        </button>
        <button class="btn-secondary" style="margin-top: 12rpx;" bindtap="onContinueChat">继续修改偏好</button>
        <view class="retry-area" wx:if="{{joinError}}">
            <text class="match-error">{{joinError}}</text>
            <text class="match-retry" catchtap="onJoinQueue">点击重试</text>
        </view>
    </view>
    <view class="test-push-panel safe-bottom" wx:if="{{showTestPush && !fromPush && chatComplete && alreadyJoined}}">
        <view class="test-push-header">Push test</view>
        <input class="test-push-input" value="{{testPushOpenid}}" placeholder="openid" bindinput="onTestPushInput" />
        <button class="test-push-btn" catchtap="onTestPushSend" disabled="{{testPushSending}}">
            {{testPushSending ? 'Sending...' : 'Send test push'}}
        </button>
        <button class="test-push-btn-secondary" catchtap="onSimulatePushEntry">Simulate push entry</button>
    </view>

</view>
