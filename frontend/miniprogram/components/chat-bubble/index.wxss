.bubble-wrapper {
    display: flex;
    align-items: flex-start;
    margin-bottom: 24rpx;
    padding: 0 32rpx;
}

.bubble-wrapper.right {
    flex-direction: row-reverse;
}

.avatar {
    width: 64rpx;
    height: 64rpx;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20rpx;
    font-weight: 700;
    letter-spacing: 1rpx;
    flex-shrink: 0;
    border: 2rpx solid #000000;
}

.left .avatar {
    background: #000000;
    color: #FFFFFF;
}

.right .avatar {
    background: #FFFFFF;
    color: #000000;
}

.bubble {
    max-width: 70%;
    padding: 20rpx 28rpx;
    font-size: 28rpx;
    line-height: 1.7;
    word-break: break-all;
}

.left .bubble {
    margin-left: 16rpx;
    background: #F5F5F5;
    color: #000000;
}

.right .bubble {
    margin-right: 16rpx;
    background: #000000;
    color: #FFFFFF;
}

.typing-indicator {
    display: flex;
    gap: 8rpx;
    padding: 8rpx 0;
}

.dot {
    width: 10rpx;
    height: 10rpx;
    background: #999999;
    animation: typing 1.4s infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
    0%, 80%, 100% { opacity: 0.2; }
    40% { opacity: 1; }
}
